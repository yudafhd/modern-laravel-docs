{
    "name": "yudafhd/modern-laravel-docs",
    "description": "A modern and interactive API documentation dashboard for Laravel powered by Scramble and React",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Yuda",
            "email": "ahmadyudafahrudin@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "dedoc/scramble": "^0.13|^0.14"
    },
    "autoload": {
        "psr-4": {
            "Yudafhd\\LaravelDocs\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yudafhd\\LaravelDocs\\DocsServiceProvider"
            ]
        }
    }
}
